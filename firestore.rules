rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── helpers ────────────────────────────────────────────────────────────

    function signedIn() {
      return request.auth != null;
    }

    function myDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      return signedIn() && myDoc().role == 'superAdmin';
    }

    function isUniversityAdmin(uniId) {
      return signedIn()
          && myDoc().role == 'universityAdmin'
          && myDoc().universityId == uniId;
    }

    function isPresidentOf(clubId) {
      return signedIn()
          && myDoc().role == 'president'
          && myDoc().clubId == clubId;
    }

    function isVPOf(clubId) {
      return signedIn()
          && myDoc().role == 'vicePresident'
          && myDoc().clubId == clubId;
    }

    function sameUniversity(uniId) {
      return signedIn() && myDoc().universityId == uniId;
    }

    function isClubLeader(clubId) {
      return isPresidentOf(clubId) || isVPOf(clubId);
    }

    function isAdmin() {
      return isSuperAdmin() || signedIn() && myDoc().role == 'universityAdmin';
    }

    // ─── /users ─────────────────────────────────────────────────────────────

    match /users/{userId} {
      allow read: if signedIn() && (
        request.auth.uid == userId
        || isSuperAdmin()
        || isUniversityAdmin(resource.data.universityId)
      );
      allow create: if signedIn()
                    && request.auth.uid == userId
                    && request.resource.data.role == 'student';
      allow update: if signedIn() && (
        (request.auth.uid == userId
          && !request.resource.data.diff(resource.data).affectedKeys()
                .hasAny(['role', 'universityId', 'clubId']))
        || isSuperAdmin()
        || isUniversityAdmin(resource.data.universityId)
      );
    }

    // ─── /universities ───────────────────────────────────────────────────────

    match /universities/{universityId} {
      // Public read: needed during registration before the user has an auth account.
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // ─── /clubs ──────────────────────────────────────────────────────────────

    match /clubs/{clubId} {
      allow read: if sameUniversity(resource.data.universityId);
      allow create: if isUniversityAdmin(request.resource.data.universityId);
      allow update: if isUniversityAdmin(resource.data.universityId)
                    || isClubLeader(clubId)
                    || isSuperAdmin()
                    // Members can increment only the score field (challenge submissions)
                    || (signedIn()
                        && sameUniversity(resource.data.universityId)
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['score']));
      allow delete: if isUniversityAdmin(resource.data.universityId);
    }

    // ─── /events ─────────────────────────────────────────────────────────────

    match /events/{eventId} {
      allow read: if sameUniversity(resource.data.universityId);
      allow create: if isClubLeader(request.resource.data.clubId)
                    && sameUniversity(request.resource.data.universityId);
      allow update: if isClubLeader(resource.data.clubId);
      allow delete: if isPresidentOf(resource.data.clubId)
                    || isUniversityAdmin(resource.data.universityId);
    }

    // ─── /joinRequests ───────────────────────────────────────────────────────

    match /joinRequests/{requestId} {
      allow read: if signedIn() && (
        resource.data.userId == request.auth.uid
        || isClubLeader(resource.data.clubId)
        || isUniversityAdmin(resource.data.universityId)
        || isSuperAdmin()
      );
      allow create: if signedIn()
                    && request.resource.data.userId == request.auth.uid
                    && sameUniversity(request.resource.data.universityId)
                    && request.resource.data.status == 'pending';
      allow update: if isClubLeader(resource.data.clubId)
                    || isUniversityAdmin(resource.data.universityId);
    }

    // ─── /positionRequests ───────────────────────────────────────────────────

    match /positionRequests/{requestId} {
      allow read: if signedIn() && (
        resource.data.userId == request.auth.uid
        || isClubLeader(resource.data.clubId)
        || isUniversityAdmin(resource.data.universityId)
        || isSuperAdmin()
      );
      allow create: if signedIn()
                    && request.resource.data.userId == request.auth.uid
                    && sameUniversity(request.resource.data.universityId)
                    && request.resource.data.status == 'pending';
      allow update: if isClubLeader(resource.data.clubId)
                    || isUniversityAdmin(resource.data.universityId)
                    || isSuperAdmin();
    }

    // ─── /clubMembers ────────────────────────────────────────────────────────

    match /clubMembers/{memberId} {
      allow read: if sameUniversity(resource.data.universityId);
      allow write: if false;
    }

    // ─── /eventRegistrations ─────────────────────────────────────────────────

    match /eventRegistrations/{registrationId} {
      allow read: if signedIn() && (
        resource.data.userId == request.auth.uid
        || isClubLeader(resource.data.clubId)
      );
      allow create: if signedIn()
                    && request.resource.data.userId == request.auth.uid
                    && sameUniversity(request.resource.data.universityId);
      allow delete: if resource.data.userId == request.auth.uid;
    }

    // ─── /eventRatings ───────────────────────────────────────────────────────

    match /eventRatings/{ratingId} {
      allow read: if sameUniversity(resource.data.universityId);
      allow create: if signedIn()
                    && request.resource.data.userId == request.auth.uid
                    && sameUniversity(request.resource.data.universityId);
    }

    // ─── /notifications ──────────────────────────────────────────────────────

    match /notifications/{notificationId} {
      allow read, update: if signedIn()
                           && resource.data.userId == request.auth.uid;
      // Any signed-in user can create a notification for another user.
      // Reading is still restricted to the target user (userId == auth.uid above),
      // so notifications remain private. This is needed because students notify
      // the president on join requests, members notify the president on VP requests, etc.
      allow create: if signedIn();
    }

    // ─── /challenges ─────────────────────────────────────────────────────────

    match /challenges/{challengeId} {
      allow read: if sameUniversity(resource.data.universityId);

      // President/VP can always create for their university.
      // Regular members can create if their clubId matches (used in the auto-generate flow).
      // The myDoc().clubId == clubId check can fail if the president was added
      // manually without setting clubId, so we also accept by role.
      allow create: if signedIn()
                    && myDoc().universityId == request.resource.data.universityId
                    && (
                        myDoc().clubId == request.resource.data.clubId
                        || myDoc().role == 'president'
                        || myDoc().role == 'vicePresident'
                    );

      // Only president / VP can overwrite or edit
      allow update: if isClubLeader(resource.data.clubId)
                    || isSuperAdmin();
    }

    // ─── /challengeSubmissions ───────────────────────────────────────────────

    match /challengeSubmissions/{submissionId} {
      allow read: if signedIn() && (
        resource.data.userId == request.auth.uid
        || isClubLeader(resource.data.clubId)
        || isAdmin()
      );
      allow create: if signedIn()
                    && request.resource.data.userId == request.auth.uid
                    && sameUniversity(request.resource.data.universityId);
      allow update: if resource.data.userId == request.auth.uid;
    }

    // ─── /clubReports ────────────────────────────────────────────────────────

    match /clubReports/{clubId} {
      allow read: if signedIn() && (
        isPresidentOf(clubId)
        || isVPOf(clubId)
        || isAdmin()
      );
      allow write: if false;
    }

    // ─── /supportTickets ─────────────────────────────────────────────────────

    match /supportTickets/{ticketId} {
      allow read: if signedIn() && (
        resource.data.userId == request.auth.uid
        || isAdmin()
      );
      allow create: if signedIn()
                    && request.resource.data.userId == request.auth.uid;
      allow update: if signedIn() && (
        resource.data.userId == request.auth.uid
        || isAdmin()
      );
    }
  }
}
