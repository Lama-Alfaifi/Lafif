rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── helpers ────────────────────────────────────────────────────────────

    function signedIn() {
      return request.auth != null;
    }

    function me() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      return signedIn() && me().role == 'superAdmin';
    }

    function isUniversityAdmin(uniId) {
      return signedIn()
          && me().role == 'universityAdmin'
          && me().universityId == uniId;
    }

    function isPresidentOf(clubId) {
      return signedIn()
          && me().role == 'president'
          && me().clubId == clubId;
    }

    function isVPOf(clubId) {
      return signedIn()
          && me().role == 'vicePresident'
          && me().clubId == clubId;
    }

    function sameUniversity(uniId) {
      return signedIn() && me().universityId == uniId;
    }

    function isClubLeader(clubId) {
      return isPresidentOf(clubId) || isVPOf(clubId);
    }

    // ─── /users ─────────────────────────────────────────────────────────────

    match /users/{userId} {
      // Read: own doc, superAdmin, or universityAdmin of same university
      allow read: if signedIn() && (
        request.auth.uid == userId
        || isSuperAdmin()
        || isUniversityAdmin(resource.data.universityId)
      );

      // Create: only the newly registered user creates their own doc
      allow create: if signedIn()
                    && request.auth.uid == userId
                    && request.resource.data.role == 'student';

      // Update: own doc (limited fields), superAdmin, or universityAdmin
      allow update: if signedIn() && (
        (request.auth.uid == userId
          && !request.resource.data.diff(resource.data).affectedKeys()
                .hasAny(['role', 'universityId', 'clubId']))
        || isSuperAdmin()
        || isUniversityAdmin(resource.data.universityId)
      );
    }

    // ─── /universities ───────────────────────────────────────────────────────

    match /universities/{universityId} {
      allow read: if signedIn();
      allow write: if isSuperAdmin();
    }

    // ─── /clubs ──────────────────────────────────────────────────────────────

    match /clubs/{clubId} {
      allow read: if sameUniversity(resource.data.universityId);
      allow create: if isUniversityAdmin(request.resource.data.universityId);
      allow update: if isUniversityAdmin(resource.data.universityId)
                    || isClubLeader(clubId);
      allow delete: if isUniversityAdmin(resource.data.universityId);
    }

    // ─── /events ─────────────────────────────────────────────────────────────

    match /events/{eventId} {
      allow read: if sameUniversity(resource.data.universityId);
      allow create: if isClubLeader(request.resource.data.clubId)
                    && sameUniversity(request.resource.data.universityId);
      allow update: if isClubLeader(resource.data.clubId);
      allow delete: if isPresidentOf(resource.data.clubId)
                    || isUniversityAdmin(resource.data.universityId);
    }

    // ─── /joinRequests ───────────────────────────────────────────────────────

    match /joinRequests/{requestId} {
      allow read: if signedIn() && (
        resource.data.userId == request.auth.uid
        || isClubLeader(resource.data.clubId)
        || isUniversityAdmin(resource.data.universityId)
      );

      // Student submits their own request
      allow create: if signedIn()
                    && request.resource.data.userId == request.auth.uid
                    && sameUniversity(request.resource.data.universityId)
                    && request.resource.data.status == 'pending';

      // Only president / VP / universityAdmin can change status
      allow update: if isClubLeader(resource.data.clubId)
                    || isUniversityAdmin(resource.data.universityId);
    }

    // ─── /clubMembers ────────────────────────────────────────────────────────

    match /clubMembers/{memberId} {
      allow read: if sameUniversity(resource.data.universityId);
      // Written by Firebase Functions only (Admin SDK bypasses rules)
      allow write: if false;
    }

    // ─── /eventRegistrations ─────────────────────────────────────────────────

    match /eventRegistrations/{registrationId} {
      allow read: if signedIn() && (
        resource.data.userId == request.auth.uid
        || isClubLeader(resource.data.clubId)
      );
      allow create: if signedIn()
                    && request.resource.data.userId == request.auth.uid
                    && sameUniversity(request.resource.data.universityId);
      allow delete: if resource.data.userId == request.auth.uid;
    }

    // ─── /eventRatings ───────────────────────────────────────────────────────

    match /eventRatings/{ratingId} {
      allow read: if sameUniversity(resource.data.universityId);
      allow create: if signedIn()
                    && request.resource.data.userId == request.auth.uid
                    && sameUniversity(request.resource.data.universityId);
    }

    // ─── /notifications ──────────────────────────────────────────────────────

    match /notifications/{notificationId} {
      // Users read and mark their own notifications
      allow read, update: if signedIn()
                           && resource.data.userId == request.auth.uid;
      // Written by Firebase Functions (Admin SDK bypasses rules)
      allow create: if false;
    }

    // ─── /challenges ─────────────────────────────────────────────────────────

    match /challenges/{challengeId} {
      allow read: if sameUniversity(resource.data.universityId);
      allow create, update: if isClubLeader(request.resource.data.clubId)
                             && sameUniversity(request.resource.data.universityId);
    }
  }
}
